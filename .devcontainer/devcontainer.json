// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
	"name": "Debian",
	// Prebuilt image with the tool set baked in (htmlq, pandoc, tmux, ripgrep,
	// dolt, beads, Claude Code, Codex, node LTS via the node feature).
	// Source: ./base-image/ — built and released nightly by
	// .github/workflows/devcontainer-image.yml. Rebuilds reuse the locally
	// cached image; `docker pull` this tag on the docker host, then rebuild,
	// to pick up a newer release.
	"image": "ghcr.io/momsdish-corp/devcontainer-public:latest",
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
	"workspaceFolder": "/workspace",

    // Inherit environment variables from host (see /etc/environment on host)
	"containerEnv": {
		"EXAMPLE": "${localEnv:EXAMPLE}"
	},

	"updateContentCommand": "./.devcontainer/update-content.sh",
	"postStartCommand": "./.devcontainer/post-start.sh",

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [3004]

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				// Beads issue tracker UI (pairs with the bd CLI baked into the prebuilt image)
				"planet57.vscode-beads"
			]
		}
	},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	"remoteUser": "root"
	}
